[
  {
    "kernelSource": {
      "name": "oneplus_sm8250",
      "repo": "https://github.com/LineageOS/android_kernel_oneplus_sm8250",
      "branch": "lineage-23.0",
      "device": "merge",
      "defconfig": "defconfig"
    },
    "withKernelSU": true,
    "toolchains": [
      {
        "repo": "https://github.com/LineageOS/android_prebuilts_gcc_linux-x86_aarch64_aarch64-linux-gnu-9.3",
        "branch": "lineage-23.0",
        "name": "gcc",
        "binPath": ["bin"]
      }
    ],
    "ccache": true,
    "params": {
      "ARCH": "arm64",
      "CC": "gcc/bin/aarch64-linux-android-gcc",
      "externalCommand": {
        "CROSS_COMPILE": "gcc/bin/aarch64-linux-",
        "LD": "gcc/bin/aarch64-linux-ld",
        "AR": "gcc/bin/aarch64-linux-ar",
        "NM": "gcc/bin/aarch64-linux-nm",
        "OBJCOPY": "gcc/bin/aarch64-linux-objcopy",
        "OBJDUMP": "gcc/bin/aarch64-linux-objdump",
        "READELF": "gcc/bin/aarch64-linux-readelf",
        "OBJSIZE": "gcc/bin/aarch64-linux-size",
        "STRIP": "gcc/bin/aarch64-linux-strip"
      }
    },
    "AnyKernel3": {
      "use": false,
      "release": false,
      "repo": "https://github.com/osm0sis/AnyKernel3/",
      "branch": "master"
    }
  }
]
